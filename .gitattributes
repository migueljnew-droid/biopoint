# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf
*.sh text eol=lf
*.bat text eol=lf
*.cmd text eol=lf
*.ps1 text eol=lf

# Declare files that will always have CRLF line endings on checkout
*.sln text eol=crlf
*.csproj text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.rar binary
*.tar binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pyc binary
*.pdf binary
*.exe binary
*.so binary
*.dll binary
*.dylib binary
*.a binary
*.lib binary
*.ocx binary
*.cab binary
*.msi binary
*.msm binary
*.msp binary
*.xpi binary
*.deb binary
*.rpm binary
