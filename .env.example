# BioPoint Environment Configuration
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/biopoint"

# Application Environment
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# CORS Configuration
CORS_ORIGIN="http://localhost:3001,http://localhost:3002"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"

# Security
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here
HEALTH_CHECK_TOKEN=your-health-check-token-here

# AWS Configuration (for S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=biopoint-uploads

# Database Performance Settings
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_SLOW_QUERY_THRESHOLD=500
DB_QUERY_TIMEOUT=30000

# Monitoring
ENABLE_DB_MONITORING=true
DB_METRICS_INTERVAL=30000
DB_HEALTH_CHECK_INTERVAL=10000
