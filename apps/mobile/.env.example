# BioPoint Mobile Environment Variables
# Copy to .env and fill in values, or set via: eas env:create

# API URL (required) - your deployed Fly.io backend
EXPO_PUBLIC_API_URL=https://biopoint-api.fly.dev

# RevenueCat (optional - IAP will be disabled without these)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google Sign-In (optional - Google login disabled without this)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
