{
  "expo": {
    "name": "BioPoint",
    "slug": "biopoint",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "biopoint",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biopoint.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "BioPoint uses your camera to scan food and lab reports for analysis.",
        "NSPhotoLibraryUsageDescription": "BioPoint accesses your photo library to upload lab reports and progress photos.",
        "NSPhotoLibraryAddUsageDescription": "BioPoint saves progress photos to your library.",
        "NSFaceIDUsageDescription": "BioPoint uses Face ID to protect your health data.",
        "NSHealthShareUsageDescription": "BioPoint reads your health data from Apple Health to calculate your BioPoint Score.",
        "NSHealthUpdateUsageDescription": "BioPoint writes health data to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true,
        "com.apple.security.application-groups": [
          "group.com.biopoint.app"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.louisgold.biopoint"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "@bacons/apple-targets",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b4fad390-ffb4-4771-b244-ec395f364fd0"
      }
    },
    "owner": "louisgoldlive"
  }
}
