{
    "name": "@biopoint/api",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "clean": "rm -rf dist",
        "test": "NODE_OPTIONS=--disable-warning=DEP0169 vitest run",
        "test:watch": "NODE_OPTIONS=--disable-warning=DEP0169 vitest",
        "test:coverage": "NODE_OPTIONS=--disable-warning=DEP0169 vitest run --coverage",
        "test:security": "NODE_OPTIONS=--disable-warning=DEP0169 vitest run --reporter=verbose src/__tests__/security/",
        "test:compliance": "NODE_OPTIONS=--disable-warning=DEP0169 vitest run --reporter=verbose src/__tests__/compliance/",
        "test:integration": "NODE_OPTIONS=--disable-warning=DEP0169 vitest run --reporter=verbose src/__tests__/integration/"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.500.0",
        "@aws-sdk/s3-request-presigner": "^3.500.0",
        "@biopoint/db": "*",
        "@biopoint/shared": "*",
        "@fastify/cors": "^10.1.0",
        "@fastify/helmet": "^12.0.1",
        "@fastify/rate-limit": "^10.3.0",
        "@google-cloud/vertexai": "^1.10.0",
        "@google/generative-ai": "^0.24.1",
        "bcrypt": "^5.1.1",
        "dotenv": "^16.3.1",
        "fastify": "^5.7.4",
        "file-type": "^19.6.0",
        "ioredis": "^5.9.3",
        "jsonwebtoken": "^9.0.2",
        "openai": "^6.15.0",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@faker-js/faker": "^8.4.1",
        "@sentry/types": "^10.39.0",
        "@types/bcrypt": "^5.0.2",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.10.0",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^9.0.7",
        "@vitest/coverage-v8": "^1.2.0",
        "date-fns": "^4.1.0",
        "pino-pretty": "^13.1.3",
        "supertest": "^6.3.4",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "vitest": "^1.2.0"
    }
}
