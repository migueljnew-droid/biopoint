{
  "name": "biopoint",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "db"
  ],
  "scripts": {
    "dev:api": "doppler run -- npm run dev -w @biopoint/api",
    "dev:mobile": "doppler run -- npm run start -w @biopoint/mobile",
    "build:api": "doppler run -- npm run build -w @biopoint/api",
    "build:shared": "doppler run -- npm run build -w @biopoint/shared",
    "db:generate": "doppler run -- npm run generate -w @biopoint/db",
    "db:migrate": "doppler run -- npm run migrate -w @biopoint/db",
    "db:push": "doppler run -- npm run push -w @biopoint/db",
    "db:seed": "doppler run -- npm run seed -w @biopoint/db",
    "db:studio": "doppler run -- npm run studio -w @biopoint/db",
    "db:optimize": "./scripts/database-optimize.sh",
    "db:health": "curl -s http://localhost:3000/health/db | jq .",
    "db:performance": "node -e \"console.log(JSON.stringify(require('./apps/api/src/services/databasePerformance.js').dbPerformanceMonitor.getMetrics(), null, 2))\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "turbo run test:watch",
    "test:api": "npm run test -w @biopoint/api",
    "test:mobile": "npm run test -w @biopoint/mobile",
    "test:db": "npm run test -w @biopoint/db",
    "test:all": "npm run test:coverage && npm run test:security && npm run test:compliance",
    "test:security": "turbo run test:security",
    "test:compliance": "turbo run test:compliance",
    "test:encryption": "doppler run -- npm run test -w @biopoint/api -- --testPathPattern=encryption.test.ts",
    "test:performance": "doppler run -- npm run test -w @biopoint/api -- --testPathPattern=performance.test.ts",
    "test:load": "npm run load:test:all",
    "test:load:baseline": "cd tests/load && npm run test:baseline",
    "test:load:stress": "cd tests/load && npm run test:stress",
    "test:load:spike": "cd tests/load && npm run test:spike",
    "test:load:endurance": "cd tests/load && npm run test:endurance",
    "test:load:database": "cd tests/load && npm run test:database",
    "load:test:all": "cd tests/load && ./run-all-tests.sh",
    "load:test:endurance": "cd tests/load && ./run-all-tests.sh --endurance",
    "load:report": "cd tests/load && node report-generator.js",
    "load:metrics": "cd tests/load && node metrics-exporter.js",
    "load:install": "cd tests/load && npm install",
    "encryption:check": "node scripts/check-unencrypted-phi.js",
    "encryption:check:detailed": "node scripts/check-unencrypted-phi.js --detailed",
    "encryption:rotate": "./scripts/rotate-encryption-keys.sh",
    "encryption:validate": "node -e \"const { validateEncryptionSetup } = require('./apps/api/src/utils/encryption.js'); validateEncryptionSetup().then(console.log).catch(console.error)\"",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "lint": "doppler run -- turbo run lint",
    "clean": "doppler run -- turbo run clean",
    "doppler:setup": "doppler setup",
    "doppler:login": "doppler login",
    "secrets:list": "doppler secrets",
    "secrets:audit": "doppler activity",
    "secrets:migrate": "./scripts/migrate-to-doppler.sh",
    "env:dev": "doppler run --config dev",
    "env:staging": "doppler run --config staging",
    "env:prod": "doppler run --config production"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "react": "19.1.0",
    "tsx": "^4.7.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1"
  }
}
