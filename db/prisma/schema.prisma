generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["metrics"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  role              Role               @default(USER)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  auditLogs         AuditLog[]
  bioPointScores    BioPointScore[]
  breachIncidents   BreachIncident[]   @relation("ReportedBy")
  complianceAudits  ComplianceAudit[]  @relation("AuditedBy")
  complianceEvents  ComplianceEvent[]
  consentRecords    ConsentRecord[]
  dailyLogs         DailyLog[]
  deletionRequests  DeletionRequest?
  disclosureLogs    DisclosureLog[]
  downloadLogs      DownloadLog[]
  fastingProtocols  FastingProtocol[]
  fastingSessions   FastingSession[]
  foodLogs          FoodLog[]
  groupMemberships  GroupMember[]
  labMarkers        LabMarker[]
  labReports        LabReport[]
  mealEntries       MealEntry[]
  posts             Post[]
  profile           Profile?
  publicProfile     UserPublicProfile?
  userStats         UserStats?
  progressPhotos    ProgressPhoto[]
  refreshTokens     RefreshToken[]
  reminderSchedules ReminderSchedule[]
  revokedUrls       RevokedUrl[]       @relation("RevokedByUser")
  stacks            Stack[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  sex                   String?
  dateOfBirth           DateTime?
  dateOfBirth_encrypted String?
  heightCm              Float?
  baselineWeightKg      Float?
  goals                 String[]  @default([])
  dietStyle             String?
  currentInterventions  String?
  encryption_version    Int?      @default(1)
  encryption_metadata   Json?     @default("{}")
  consentNotMedical     Boolean   @default(false)
  consentDataStorage    Boolean   @default(false)
  consentResearch       Boolean   @default(false)
  consentResearchAt     DateTime?
  calorieTarget         Int?
  proteinTargetG        Float?
  carbsTargetG          Float?
  fatTargetG            Float?
  onboardingComplete    Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPublicProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  username    String?  @unique
  avatarS3Key String?
  bio         String?  @db.VarChar(300)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
}

model UserStats {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  totalDaysLogged   Int      @default(0)
  totalStacksActive Int      @default(0)
  totalLabsUploaded Int      @default(0)
  badgesJson        Json     @default("[]")
  computedAt        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String
  contentType String
  contentId   String
  contentName String
  reason      String
  createdAt   DateTime @default(now())

  @@index([contentType, contentId])
}

model Stack {
  id        String      @id @default(cuid())
  userId    String
  name      String
  goal      String?
  startDate DateTime    @default(now())
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     StackItem[]

  @@index([userId])
  @@index([userId, isActive])
}

model StackItem {
  id                  String             @id @default(cuid())
  stackId             String
  name                String
  dose                Float
  unit                String
  route               String?
  frequency           String
  timing              String?
  cycleJson           Json?
  notes               String?
  notes_encrypted     String?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  encryption_version  Int?               @default(1)
  encryption_metadata Json?              @default("{}")
  scheduleDays        Int[]
  complianceEvents    ComplianceEvent[]
  reminders           ReminderSchedule[]
  stack               Stack              @relation(fields: [stackId], references: [id], onDelete: Cascade)
}

model ComplianceEvent {
  id          String    @id @default(cuid())
  userId      String
  stackItemId String
  takenAt     DateTime  @default(now())
  notes       String?
  stackItem   StackItem @relation(fields: [stackItemId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
}

model ReminderSchedule {
  id          String    @id @default(cuid())
  userId      String
  stackItemId String
  time        String
  daysOfWeek  Int[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  stackItem   StackItem @relation(fields: [stackItemId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LabReport {
  id                  String      @id @default(cuid())
  userId              String
  filename            String
  s3Key               String
  uploadedAt          DateTime    @default(now())
  reportDate          DateTime?
  notes               String?
  notes_encrypted     String?
  encryption_version  Int?        @default(1)
  encryption_metadata Json?       @default("{}")
  markers             LabMarker[]
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LabMarker {
  id                  String     @id @default(cuid())
  labReportId         String?
  userId              String
  name                String
  value               Float?
  value_encrypted     String?
  unit                String
  refRangeLow         Float?
  refRangeHigh        Float?
  recordedAt          DateTime   @default(now())
  notes               String?
  encryption_version  Int?       @default(1)
  encryption_metadata Json?      @default("{}")
  labReport           LabReport? @relation(fields: [labReportId], references: [id], onDelete: Cascade)
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, recordedAt])
}

model ProgressPhoto {
  id                  String   @id @default(cuid())
  userId              String
  originalS3Key       String
  alignedS3Key        String?
  category            String
  capturedAt          DateTime @default(now())
  weightKg            Float?
  notes               String?
  notes_encrypted     String?
  alignmentStatus     String   @default("pending")
  createdAt           DateTime @default(now())
  encryption_version  Int?     @default(1)
  encryption_metadata Json?    @default("{}")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capturedAt])
}

model DailyLog {
  id                  String   @id @default(cuid())
  userId              String
  date                DateTime @db.Date
  weightKg            Float?
  sleepHours          Float?
  sleepQuality        Int?
  energyLevel         Int?
  focusLevel          Int?
  moodLevel           Int?
  notes               String?
  notes_encrypted     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  encryption_version  Int?     @default(1)
  encryption_metadata Json?    @default("{}")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model BioPointScore {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  score     Int
  breakdown Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([score])
}

model FastingProtocol {
  id           String           @id @default(cuid())
  userId       String?
  name         String
  slug         String           @unique
  fastingHours Float
  eatingHours  Float
  description  String?
  icon         String?
  isSystem     Boolean          @default(false)
  createdAt    DateTime         @default(now())
  user         User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     FastingSession[]

  @@index([userId])
  @@index([isSystem])
}

model FastingSession {
  id             String          @id @default(cuid())
  userId         String
  protocolId     String
  status         FastingStatus   @default(ACTIVE)
  startedAt      DateTime        @default(now())
  targetEndAt    DateTime
  endedAt        DateTime?
  durationMins   Int?
  notes          String?
  moodBefore     Int?
  energyBefore   Int?
  moodAfter      Int?
  energyAfter    Int?
  zonesReached   Json?
  breakingMealId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  protocol       FastingProtocol @relation(fields: [protocolId], references: [id])
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, startedAt])
}

model FoodLog {
  id            String      @id @default(cuid())
  userId        String
  date          DateTime    @db.Date
  totalCalories Int         @default(0)
  totalProteinG Float       @default(0)
  totalCarbsG   Float       @default(0)
  totalFatG     Float       @default(0)
  totalFiberG   Float       @default(0)
  mealCount     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals         MealEntry[]

  @@unique([userId, date])
}

model MealEntry {
  id           String   @id @default(cuid())
  userId       String
  foodLogId    String
  mealType     MealType
  name         String
  calories     Int
  proteinG     Float    @default(0)
  carbsG       Float    @default(0)
  fatG         Float    @default(0)
  fiberG       Float    @default(0)
  servingSize  String?
  photoUrl     String?
  aiAnalyzed   Boolean  @default(false)
  aiConfidence Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  foodLog      FoodLog  @relation(fields: [foodLogId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([foodLogId])
}

model Group {
  id          String          @id @default(cuid())
  name        String
  description String?
  createdById String
  isPublic    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  members     GroupMember[]
  posts       Post[]
  templates   StackTemplate[]
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Post {
  id              String   @id @default(cuid())
  groupId         String
  userId          String
  content         String
  category        String   @default("general")
  mediaJson       Json?
  linkUrl         String?
  stackTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@index([groupId, category, createdAt])
}

model StackTemplate {
  id          String   @id @default(cuid())
  groupId     String?
  createdById String?
  name        String
  description String?
  goal        String?
  itemsJson   Json
  forkedFrom  String?
  forkCount   Int      @default(0)
  createdAt   DateTime @default(now())
  group       Group?   @relation(fields: [groupId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model RevokedUrl {
  id            String   @id @default(cuid())
  url           String   @unique
  revokedAt     DateTime @default(now())
  revokedBy     String
  reason        String?
  createdAt     DateTime @default(now())
  revokedByUser User     @relation("RevokedByUser", fields: [revokedBy], references: [id], onDelete: SetNull)

  @@index([url])
  @@index([revokedBy, revokedAt])
}

model DownloadLog {
  id           String   @id @default(cuid())
  userId       String?
  url          String
  s3Key        String
  downloadedAt DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  success      Boolean  @default(true)
  error        String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId, downloadedAt])
  @@index([url, downloadedAt])
  @@index([s3Key, downloadedAt])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String
  timestamp DateTime @default(now())
  count     Int      @default(1)

  @@index([key, timestamp])
}

model AccountLockout {
  id             String    @id @default(cuid())
  identifier     String    @unique
  failedAttempts Json
  lockedUntil    DateTime?
  lastAttemptAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([lockedUntil])
}

model DeletionRequest {
  id                String         @id @default(cuid())
  userId            String         @unique
  reason            String?
  requestedAt       DateTime       @default(now())
  scheduledFor      DateTime
  completedAt       DateTime?
  status            DeletionStatus @default(PENDING)
  confirmationToken String         @unique
  immediateEffect   Boolean        @default(false)
  deletedRecords    Json?
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([userId, status])
}

model ConsentRecord {
  id                String   @id @default(cuid())
  userId            String
  marketing         Boolean  @default(false)
  analytics         Boolean  @default(false)
  research          Boolean  @default(false)
  thirdPartySharing Boolean  @default(false)
  changedAt         DateTime @default(now())
  ipAddress         String?
  userAgent         String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@index([changedAt])
}

model DisclosureLog {
  id               String   @id @default(cuid())
  userId           String
  recipientName    String
  recipientType    String
  purpose          String
  dataDisclosed    String
  legalBasis       String
  dateOfDisclosure DateTime @default(now())
  method           String?
  requestedBy      String?
  approvedBy       String?
  notes            String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateOfDisclosure])
  @@index([recipientType])
  @@index([dateOfDisclosure])
}

model BreachIncident {
  id                    String         @id @default(cuid())
  reportedById          String
  title                 String
  description           String
  severity              BreachSeverity @default(MEDIUM)
  status                BreachStatus   @default(DETECTED)
  dataTypesAffected     String[]
  individualsAffected   Int            @default(0)
  discoveredAt          DateTime       @default(now())
  containedAt           DateTime?
  hhsNotifiedAt         DateTime?
  dpaNotifiedAt         DateTime?
  individualsNotifiedAt DateTime?
  rootCause             String?
  remediationSteps      String?
  lessonsLearned        String?
  closedAt              DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  reportedBy            User           @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
  @@index([discoveredAt])
  @@index([reportedById])
}

model PeptideCompound {
  id              String   @id @default(cuid())
  name            String   @unique
  aliases         String[] @default([])
  category        String
  goals           String[] @default([])
  typicalDoseMin  Float
  typicalDoseMax  Float
  typicalDoseUnit String
  halfLife        String
  route           String
  frequency       String
  cycleProtocol   String
  stackingNotes   String
  citations       Json     @default("[]")
  iuConversion    Float?
  description     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([name])
}

model ComplianceAudit {
  id              String           @id @default(cuid())
  auditedById     String
  framework       AuditFramework
  controlId       String
  controlName     String
  status          ComplianceStatus @default(NOT_ASSESSED)
  findings        String?
  evidence        String?
  remediationPlan String?
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  auditedBy       User             @relation("AuditedBy", fields: [auditedById], references: [id], onDelete: SetNull)

  @@unique([framework, controlId])
  @@index([framework, status])
  @@index([controlId])
  @@index([auditedById])
}

enum Role {
  USER
  ADMIN
}

enum FastingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum DeletionStatus {
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BreachStatus {
  DETECTED
  INVESTIGATING
  CONTAINED
  NOTIFIED
  RESOLVED
  CLOSED
}

enum AuditFramework {
  HIPAA
  GDPR
  SOC2
  ISO27001
}

enum ComplianceStatus {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
  NOT_ASSESSED
}
